{
	"name": "milkshake-ui-project",
	"version": "1.0.0",
	"description": "",
	"homepage": "https://github.com/mannsion/milkshake-ui#readme",
	"bugs": {
		"url": "https://github.com/mannsion/milkshake-ui/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mannsion/milkshake-ui.git"
	},
	"license": "ISC",
	"author": "",
	"type": "commonjs",
	"main": "index.js",
	"workspaces": [
		"@milkshake-ui/*"
	],
	"scripts": {
		"dev": "npm run site:dev",
		"build": "npm run site:build",
		"preview": "npm run site:preview",
		"docker:build": "npm run build && docker build --no-cache -t dreg.home.lab:5000/milkshake-ui-site:latest -f @milkshake-ui/site/Dockerfile @milkshake-ui/site",
		"docker:push": "docker push dreg.home.lab:5000/milkshake-ui-site:latest",
		"docker:release": "npm run docker:build && npm run docker:push",
		"docker:pull": "docker pull dreg.home.lab:5000/milkshake-ui-site:latest",
		"docker:run": "docker run --pull always -d -p 3000:3000 --name milkshake-ui-site dreg.home.lab:5000/milkshake-ui-site:latest",
		"docker:stop": "docker stop milkshake-ui-site && docker rm milkshake-ui-site",
		"site:dev": "npm run dev --workspace=@milkshake-ui/site",
		"site:build": "npm run build --workspace=@milkshake-ui/site",
		"site:preview": "npm run preview --workspace=@milkshake-ui/site",
		"site:check": "npm run check --workspace=@milkshake-ui/site",
		"site:lint": "npm run lint --workspace=@milkshake-ui/site",
		"core:build": "npm run build --workspace=@milkshake-ui/core",
		"plugin:build": "npm run build --workspace=@milkshake-ui/vite-plugin"
	},
	"devDependencies": {
		"@vanilla-extract/sprinkles": "^1.6.5",
		"eslint": "^9.34.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.11.0",
		"tslib": "^2.8.1",
		"typescript": "^5.9.2",
		"vite": "^7.1.3",
		"vite-node": "^3.2.4"
	}
}
